{
  "name": "horimisli.me",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "npm": "<11.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next-remote-watch ./posts",
    "prod": "npm run gen-feed && npm run gen-sitemap && next build",
    "gen-feed": "ts-node -r dotenv/config --esm scripts/feed.ts",
    "gen-sitemap": "ts-node -r dotenv/config --esm scripts/sitemap.ts",
    "import": "ts-node -r dotenv/config scripts/bear_note_importer.ts",
    "push-entries": "cd posts;git add .;git commit -m 'add post'; git p; cd ../public/images; git add .; git commit -m 'add post'; git p; cd ../..",
    "pull-entries": "cd posts;git pull; cd ../public/images; git pull; cd ../..",
    "release": "gh workflow run release.yml",
    "release-watch": "npm run release && gh run list --workflow=release.yml --json=databaseId --limit=1 --jq '.[].databaseId' | xargs -IJOB_ID gh run watch JOB_ID",
    "init-ci": "npm i && git clone https://${GH_TOKEN}@github.com/horimislime/articles.git ./posts && git clone https://${GH_TOKEN}@github.com/horimislime/article-images.git public/images"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "6.5.1",
    "@fortawesome/free-solid-svg-icons": "6.5.1",
    "@fortawesome/react-fontawesome": "0.2.0",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/typography": "0.5.10",
    "@vercel/analytics": "^1.0.1",
    "adm-zip": "0.5.12",
    "date-fns": "3.6.0",
    "date-fns-timezone": "0.1.4",
    "dotenv": "16.4.5",
    "gray-matter": "4.0.3",
    "luxon": "3.4.4",
    "next": "^14.0.0",
    "next-remote-watch": "2.0.0",
    "prismjs": "1.29.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-emoji-render": "2.0.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "15.5.0",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^13.0.0",
    "remark-html": "^13.0.1",
    "remark-prism": "1.3.6",
    "remark-unwrap-images": "^4.0.0",
    "rss": "1.2.2",
    "tsconfig-paths": "^4.2.0",
    "unified": "^11.0.4",
    "uniorg": "^1.1.1",
    "uniorg-extract-keywords": "^1.0.1",
    "uniorg-parse": "^2.1.1",
    "uniorg-rehype": "^1.1.1"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.5",
    "@types/luxon": "3.4.2",
    "@types/node": "20.11.30",
    "@types/prismjs": "1.26.3",
    "@types/react": "18.2.70",
    "@types/react-dom": "18.2.22",
    "@types/react-syntax-highlighter": "15.5.11",
    "@types/remark-prism": "1.3.7",
    "@types/rss": "0.0.32",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-react": "7.34.1",
    "eslint-plugin-simple-import-sort": "12.0.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.1",
    "textlint": "14.0.4",
    "textlint-rule-preset-ja-spacing": "2.3.1",
    "textlint-rule-preset-ja-technical-writing": "10.0.1",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.4.3"
  }
}
